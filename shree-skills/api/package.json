{
  "name": "shree-skills-api",
  "version": "1.0.0",
  "description": "Backend for Shree Skills",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "postinstall": "prisma generate",
   "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed": "ts-node prisma/seed.ts",
    "seed:enhanced": "ts-node prisma/seed-enhanced.ts",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "npm run prisma:generate && npm run prisma:push && npm run seed:enhanced"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "helmet": "^6.0.0",
    "express-rate-limit": "^8.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/node": "^18.15.11",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  }
}
