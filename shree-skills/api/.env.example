# Server Configuration
PORT=4000
WEB_ORIGIN=http://localhost:3000

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
# Example (replace placeholders):
# DATABASE_URL="postgresql://postgres:password@db.example.com:5432/postgres?schema=public&sslmode=require"
# Use your managed DB provider (Supabase/RDS) connection string here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require"

# JWT Secret Key (Change this in production!)
# Generate a secure random key: openssl rand -hex 32
JWT_SECRET="replace-with-a-secure-random-string"

# Optional: Logging Level
LOG_LEVEL=info

# Optional: Environment
NODE_ENV=development
